<style>
.about-section { padding: 100px 0; background: var(--dark); }
.divider { width:100%; height:1px; background:var(--border); margin-bottom:80px; }
.about-inner {
  display: grid; grid-template-columns: 320px 1fr; gap: 80px; align-items: start;
}
.about-left { display: flex; flex-direction: column; gap: 24px; }
/* ── Circular photo ring ── */
.photo-ring-wrap {
  position: relative;
  width: 280px; height: 280px;
  margin: 0 auto 24px;
  display: flex; align-items: center; justify-content: center;
}
.photo-spinner {
  position: absolute;
  inset: -6px;
  border-radius: 50%;
  background: conic-gradient(
    var(--accent) 0deg,
    var(--accent) 90deg,
    transparent 90deg,
    transparent 180deg,
    rgba(0,210,255,0.25) 180deg,
    rgba(0,210,255,0.25) 270deg,
    transparent 270deg
  );
  animation: spinRing 6s linear infinite;
}
.photo-spinner::before {
  content: '';
  position: absolute;
  inset: 3px;
  border-radius: 50%;
  background: var(--dark);
}
@keyframes spinRing { to { transform: rotate(360deg); } }
.photo-ring {
  width: 260px; height: 260px;
  border-radius: 50%;
  overflow: hidden;
  position: relative; z-index: 1;
  border: 1px solid rgba(0,210,255,0.15);
}
.about-photo {
  width: 100%; height: 100%;
  object-fit: cover; object-position: top center;
  filter: grayscale(15%) contrast(1.08) brightness(0.95);
  transition: filter 0.5s ease;
  display: block;
}
.photo-ring:hover .about-photo { filter: grayscale(0%) contrast(1) brightness(1); }
/* Small orbital dots */
.photo-dot {
  position: absolute;
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 10px rgba(0,210,255,0.8);
  animation: orbitDot 6s linear infinite;
}
.photo-dot-1 { animation-delay: 0s; }
.photo-dot-2 { animation-delay: -2s; }
.photo-dot-3 { animation-delay: -4s; width:5px;height:5px; background:rgba(0,210,255,0.5); }
@keyframes orbitDot {
  0%   { transform: rotate(0deg)   translate(143px) rotate(0deg); }
  100% { transform: rotate(360deg) translate(143px) rotate(-360deg); }
}
.about-status {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: var(--font-mono); font-size: 0.75rem; color: var(--accent);
  letter-spacing: 0.05em;
}
.status-dot {
  width:8px;height:8px;border-radius:50%;
  background:var(--accent); box-shadow:0 0 8px var(--accent);
  animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.5;transform:scale(0.8)}}
.about-meta { display: flex; flex-direction: column; gap: 10px; }
.meta-row {
  display: flex; justify-content: space-between; align-items: center;
  border-bottom: 1px solid var(--border); padding-bottom: 10px;
}
.meta-k { font-family:var(--font-mono); font-size:0.72rem; color:var(--gray-dim); letter-spacing:0.06em; }
.meta-v { font-family:var(--font-mono); font-size:0.78rem; color:var(--gray); }
/* Right */
.about-eyebrow { font-family:var(--font-mono); font-size:0.85rem; color:var(--accent); margin-bottom:12px; }
.about-title {
  font-family: var(--font-head);
  font-size: clamp(2rem, 4vw, 3.2rem);
  font-weight: 700; line-height: 1.1;
  letter-spacing: -0.03em; color: var(--white);
  margin-bottom: 28px;
}
.accent-text { color: var(--accent); }
.about-text { display: flex; flex-direction: column; gap: 16px; margin-bottom: 36px; }
.about-text p { font-family:var(--font-mono); font-size:0.88rem; color:var(--gray); line-height:1.85; }
.about-text strong { color: var(--white); font-weight:600; }
/* Social CTA Links */
.about-links {
  display: flex; flex-wrap: wrap; gap: 12px;
  margin-bottom: 32px;
}
.about-link-btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 10px 20px;
  font-family: var(--font-mono); font-size: 0.8rem; font-weight: 500;
  border-radius: 4px; text-decoration: none;
  border: 1px solid transparent;
  transition: all 0.25s ease;
  letter-spacing: 0.04em;
}
.github-btn {
  background: rgba(255,255,255,0.06);
  color: var(--gray);
  border-color: var(--border);
}
.github-btn:hover {
  background: rgba(255,255,255,0.12);
  color: var(--white);
  border-color: rgba(255,255,255,0.25);
  transform: translateY(-2px);
  box-shadow: 0 4px 20px rgba(0,0,0,0.3);
}
.linkedin-btn {
  background: rgba(0, 119, 181, 0.12);
  color: #58b4d8;
  border-color: rgba(0, 119, 181, 0.35);
}
.linkedin-btn:hover {
  background: rgba(0, 119, 181, 0.22);
  color: #7dcfee;
  border-color: rgba(0, 119, 181, 0.6);
  transform: translateY(-2px);
  box-shadow: 0 4px 20px rgba(0,119,181,0.2);
}
.about-stats {
  display: grid; grid-template-columns: repeat(3,1fr); gap: 20px;
  padding: 28px; background: var(--surface);
  border: 1px solid var(--border); border-radius: 4px;
  margin-bottom: 32px;
}
.astat { text-align:center; }
.astat-n {
  font-family:var(--font-head); font-size:2.2rem; font-weight:700;
  color:var(--accent); line-height:1;
}
.astat-u { font-family:var(--font-head); font-size:1.4rem; color:var(--accent); }
.astat p { font-family:var(--font-mono); font-size:0.72rem; color:var(--gray-dim); margin-top:4px; letter-spacing:0.06em; }
@media(max-width:900px){
  .about-inner{grid-template-columns:1fr;gap:48px;}
  .about-photo{max-width:260px;}
}
@media(max-width:480px){ .about-stats{grid-template-columns:1fr 1fr;} }
</style>

<script>
const obs = new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(!e.isIntersecting) return;
    e.target.querySelectorAll<HTMLElement>('[data-to]').forEach(el=>{
      const to=parseInt(el.dataset.to||'0');
      let n=0; const step=Math.ceil(to/40);
      const t=setInterval(()=>{n=Math.min(n+step,to);el.textContent=String(n);if(n>=to)clearInterval(t);},25);
    });
    obs.unobserve(e.target);
  });
},{threshold:0.3});
document.querySelectorAll('.about-stats').forEach(el=>obs.observe(el));
</script>
