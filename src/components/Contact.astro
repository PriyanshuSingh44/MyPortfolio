<!-- FOOTER -->
<footer class="footer">
  <div class="container footer-inner">
    <span class="footer-logo">PS<span class="accent-text">.</span></span>
    <span class="footer-copy">Designed &amp; Built by Priyanshu Singh · 2026</span>
    <span class="footer-built">Built with Astro ✦</span>
  </div>
</footer>

<style>
.connect-section { padding: 110px 0; background: var(--dark); }
.divider-top { height: 1px; background: var(--border); margin-bottom: 80px; }

.connect-inner {
  display: grid;
  grid-template-columns: 1fr 420px;
  gap: 80px;
  align-items: start;
}

/* ── Left ── */
.connect-heading {
  font-family: var(--font-head);
  font-size: clamp(3rem, 6vw, 5.5rem);
  font-weight: 700;
  letter-spacing: -0.04em;
  color: var(--white);
  line-height: 0.95;
  margin: 12px 0 24px;
}
.accent-text { color: var(--accent); }

.connect-sub {
  font-family: var(--font-mono);
  font-size: 0.85rem;
  color: var(--gray);
  line-height: 1.85;
  max-width: 400px;
  margin-bottom: 40px;
}

/* Social stack */
.social-stack { display: flex; flex-direction: column; gap: 10px; }

.social-btn {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 14px 18px;
  background: rgba(255,255,255,0.02);
  border: 1px solid var(--border);
  border-radius: 6px;
  text-decoration: none;
  transition: background 0.22s ease, border-color 0.22s ease, transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
  cursor: pointer;
}
.social-btn:hover {
  background: rgba(0,210,255,0.05);
  border-color: rgba(0,210,255,0.3);
  transform: translateX(6px);
}

.social-icon {
  width: 38px; height: 38px;
  border-radius: 8px;
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  color: var(--gray);
  flex-shrink: 0;
  transition: background 0.2s, color 0.2s;
}
.social-btn:hover .social-icon {
  background: rgba(0,210,255,0.1);
  border-color: rgba(0,210,255,0.3);
  color: var(--accent);
}

.social-info { flex: 1; display: flex; flex-direction: column; gap: 2px; }
.social-label {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--gray-dim);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}
.social-val {
  font-family: var(--font-mono);
  font-size: 0.82rem;
  color: var(--gray);
  transition: color 0.2s;
}
.social-btn:hover .social-val { color: var(--white); }

.social-arrow {
  font-size: 1rem;
  color: var(--gray-dim);
  transition: color 0.2s, transform 0.2s;
}
.social-btn:hover .social-arrow {
  color: var(--accent);
  transform: translate(2px, -2px);
}

/* ── Right: CV Card ── */
.cv-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
}

.cv-preview-img-wrap {
  position: relative;
  width: 100%; height: auto;
  overflow: hidden;
  border-radius: 4px;
}
.cv-preview-img {
  width: 100%; height: auto; display: block;
  filter: grayscale(20%) contrast(1.1);
  transition: filter 0.3s;
}
.cv-card:hover .cv-preview-img { filter: grayscale(0%); }

.cv-watermark {
  position: absolute;
  bottom: 16px; right: 16px;
  font-family: var(--font-head);
  font-size: 0.6rem;
  letter-spacing: 0.3em;
  color: rgba(0,210,255,0.6);
  font-weight: 700;
  text-shadow: 0 0 10px rgba(0,0,0,0.5);
}

.cv-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px 24px;
  border-top: 1px solid var(--border);
  background: rgba(0,0,0,0.2);
}

.cv-name {
  font-family: var(--font-head);
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--white);
}
.cv-role {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--gray-dim);
  margin-top: 2px;
}

.cv-download-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.75rem;
  padding: 10px 20px;
}

/* ── Footer ── */
.footer {
  padding: 28px 0;
  border-top: 1px solid var(--border);
  background: var(--black);
}
.footer-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 12px;
}
.footer-logo {
  font-family: var(--font-head);
  font-size: 1.2rem;
  font-weight: 700;
}
.footer-copy, .footer-built {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--gray-dim);
}

@media (max-width: 900px) {
  .connect-inner { grid-template-columns: 1fr; gap: 56px; }
  .connect-right { max-width: 480px; }
}
@media (max-width: 600px) {
  .footer-inner { flex-direction: column; text-align: center; gap: 8px; }
}
</style>
