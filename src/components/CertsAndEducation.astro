---
---
<section class="timeline-section" id="timeline">
  <div class="animated-line"></div>
  <div class="section-backdrop" style="bottom:-20px;">TIMELINE</div>
  <div class="container">
    <p class="section-eyebrow sect-reveal">Education &amp; Experience /&gt;</p>
    <h2 class="tl-heading sect-reveal d1">Timeline</h2>

    <div class="tl-wrap">
      <!-- Left column: Education -->
      <div class="tl-col">
        {[
          { id:"tl-lpu", name:"Lovely Professional University", detail:"B.Tech — AI & ML", years:"2022 – 2026", note:"Current · CGPA ongoing", current:true },
          { id:"tl-xii", name:"Kendriya Vidyalaya BKT", detail:"Class XII — PCM", years:"2021 – 2022", note:"CBSE Board" },
          { id:"tl-x",   name:"Kendriya Vidyalaya BKT", detail:"Class X — CBSE", years:"2019 – 2020", note:"CBSE Board" },
        ].map((e,i)=>(
          <div class={`tl-item tl-left slide-left d${i+2}`} id={e.id}>
            <h3 class="tl-name">{e.name}</h3>
            <p class="tl-detail">{e.detail}</p>
            {e.current && <span class="tl-current">CURRENT</span>}
            <p class="tl-years">{e.years}</p>
            <p class="tl-note">{e.note}</p>
          </div>
        ))}
      </div>

      <!-- Center line + dots -->
      <div class="tl-line-col" aria-hidden="true">
        <div class="tl-line"></div>
        <div class="tl-dot dot-accent" style="top:40px"></div>
        <div class="tl-dot dot-gray" style="top:200px"></div>
        <div class="tl-dot dot-gray" style="top:350px"></div>
        <div class="tl-dot dot-accent" style="top:520px"></div>
      </div>

      <!-- Right column: Experience/Training -->
      <div class="tl-col">
        {[
          { id:"tl-dsa", name:"CSE Pathshala", detail:"DSA with Python", years:"Jun 2025", note:"Competitive programming & Algorithms", badge:"Training" },
        ].map((e,i)=>(
          <div class={`tl-item tl-right slide-right d${i+3}`} id={e.id} style="margin-top:calc(60px)">
            <span class="tl-badge">{e.badge}</span>
            <h3 class="tl-name">{e.name}</h3>
            <p class="tl-detail">{e.detail}</p>
            <p class="tl-years">{e.years}</p>
            <p class="tl-note">{e.note}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
.timeline-section {
  padding:110px 0; background:var(--dark);
  position:relative; overflow:hidden;
}
.tl-heading {
  font-family:var(--font-head);
  font-size:clamp(2.5rem,6vw,5rem);
  font-weight:700; letter-spacing:-0.03em;
  color:var(--white); margin-bottom:64px;
}
.tl-wrap {
  display:grid;
  grid-template-columns:1fr 48px 1fr;
  gap:0; position:relative;
}
/* Items */
.tl-item {
  padding:20px 0 40px;
  display:flex; flex-direction:column; gap:6px;
}
.tl-left { text-align:right; padding-right:40px; }
.tl-right { text-align:left; padding-left:40px; }
.tl-name {
  font-family:var(--font-head);
  font-size:1.25rem; font-weight:600;
  color:var(--white);
}
.tl-detail {
  font-family:var(--font-mono);
  font-size:0.82rem; color:var(--gray);
}
.tl-years {
  font-family:var(--font-mono);
  font-size:0.78rem; color:var(--accent);
  letter-spacing:0.06em; margin-top:4px;
}
.tl-note {
  font-family:var(--font-mono);
  font-size:0.75rem; color:var(--gray-dim);
}
.tl-current {
  font-family:var(--font-mono);
  font-size:0.65rem; font-weight:700;
  background:rgba(0,210,255,0.12);
  color:var(--accent); border:1px solid rgba(0,210,255,0.3);
  padding:2px 8px; border-radius:3px;
  letter-spacing:0.1em; width:fit-content;
  align-self:flex-end;
}
.tl-badge {
  font-family:var(--font-mono);
  font-size:0.65rem; font-weight:700;
  background:rgba(255,255,255,0.06);
  color:var(--gray); border:1px solid var(--border);
  padding:2px 8px; border-radius:3px;
  letter-spacing:0.1em; width:fit-content;
}
/* Line */
.tl-line-col { position:relative; }
.tl-line {
  position:absolute; top:0; bottom:0; left:50%;
  width:1px; background:var(--border);
  transform:translateX(-50%);
}
.tl-dot {
  position:absolute; left:50%;
  width:12px; height:12px;
  border-radius:50%; transform:translate(-50%,-50%);
  z-index:2;
}
.dot-accent {
  background:var(--accent);
  box-shadow:0 0 12px rgba(0,210,255,0.6);
}
.dot-gray { background:var(--gray-dim); border:1px solid var(--border); }
@media(max-width:700px){
  .tl-wrap{grid-template-columns:1fr;gap:0;}
  .tl-line-col{display:none;}
  .tl-left,.tl-right{text-align:left;padding:0 0 32px 20px;border-left:1px solid var(--border);}
}
</style>
