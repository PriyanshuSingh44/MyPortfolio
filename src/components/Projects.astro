---
const projects = [
  {
    id:"p2", num:"01",
    title:"CareerForge — AI Career Compass",
    kicker:"Gemini AI · GitHub footprint validation",
    metric:"AI-Powered Platform",
    tech:["React","TypeScript","Gemini AI","GitHub API"],
    desc:"AI-powered career guidance platform that validates a developer's GitHub technical footprint using the GitHub API and uses Google Gemini AI to generate personalized, skill-gap-aware learning paths.",
    href:"https://github.com/PriyanshuSingh44",
  },
  {
    id:"p4", num:"02",
    title:"WiFi Anomaly Detection System",
    kicker:"Real-time detection · Live packet capture",
    metric:"Network Security ML",
    tech:["FastAPI","Socket.IO","Scikit-learn","Python"],
    desc:"Real-time network anomaly detection dashboard with ML classification models. Includes live packet capture mode, toggleable evaluation metrics, and a live results stream via Socket.IO.",
    href:"https://github.com/PriyanshuSingh44",
  },
  {
    id:"p1", num:"03",
    title:"Semantic Similarity — NLP Platform",
    kicker:"Dual-model · Sentiment-aware scoring",
    metric:"Full-Stack NLP",
    tech:["Sentence-BERT","DistilBERT","FastAPI","Python"],
    desc:"A full-stack NLP app measuring semantic similarity between two sentences using Sentence-BERT for topical similarity and DistilBERT for sentiment classification. Penalizes opposite sentiments for nuanced, context-aware scoring.",
    href:"https://github.com/PriyanshuSingh44",
  },
  {
    id:"p3", num:"04",
    title:"Predictive Maintenance Dashboard",
    kicker:"Aircraft RUL prediction · Time-series",
    metric:"Industrial ML",
    tech:["Time-Series","Scikit-learn","Regression","Python"],
    desc:"Predicts the Remaining Useful Life (RUL) of turbofan aircraft engines from sensor data. Sophisticated time-series regression with real-world industrial relevance.",
    href:"https://github.com/PriyanshuSingh44/predictive-maintenance-dashboard",
  },
  {
    id:"p5", num:"05",
    title:"House Price Prediction",
    kicker:"Kaggle top accuracy · Ensemble methods",
    metric:"Regression · Kaggle",
    tech:["XGBoost","Random Forest","Feature Engineering"],
    desc:"Predicting house prices using XGBoost and Random Forest — based on Kaggle's Intermediate ML course. Strong accuracy through feature engineering, imputation, and ensemble learning.",
    href:"https://github.com/PriyanshuSingh44/house_price_prediction_intermediate",
  },
  {
    id:"p6", num:"06",
    title:"Contact Management System",
    kicker:"Docker · Jenkins CI/CD pipeline",
    metric:"DevOps · OOP",
    tech:["Python","Docker","Jenkins","CRUD","OOP"],
    desc:"Python CRUD application with a full Docker + Jenkins CI/CD pipeline. Clean OOP architecture, file-based persistence, automated testing and deployment via Jenkins.",
    href:"https://github.com/PriyanshuSingh44/contact-management-system",
  },
];
---

<section class="projects-section" id="projects">
  <div class="animated-line"></div>
  <div class="section-backdrop">PROJECTS</div>
  <div class="container">
    <p class="section-eyebrow sect-reveal">Projects /&gt;</p>
    <h2 class="proj-heading sect-reveal">
      Selected Work<span class="accent-dot">.</span>
    </h2>

    <!-- Accordion list -->
    <div class="proj-accordion" id="projAccordion">
      {projects.map((p, i) => (
        <div
          class={`proj-row ${i === 0 ? 'active' : ''}`}
          id={p.id}
          data-index={i}
          role="button"
          tabindex="0"
          aria-expanded={i === 0 ? 'true' : 'false'}
        >
          <!-- Collapsed view (always visible) -->
          <div class="row-collapsed">
            <span class="row-num">{p.num}</span>
            <h3 class="row-title">{p.title}</h3>
            <span class="row-metric">{p.metric}</span>
            <span class="row-chevron">+</span>
          </div>

          <!-- Expanded content (revealed on active) -->
          <div class="row-expanded" aria-hidden={i === 0 ? 'false' : 'true'}>
            <div class="row-exp-inner">
              <div class="row-exp-left">
                <p class="row-kicker">{p.kicker}</p>
                <p class="row-desc">{p.desc}</p>
                <div class="row-tech">
                  {p.tech.map(t => <span class="tech-pill">{t}</span>)}
                </div>
              </div>
              <div class="row-exp-right">
                <a href={p.href} target="_blank" rel="noopener" class="row-link">
                  View on GitHub
                  <span class="arrow-icon">↗</span>
                </a>
              </div>
            </div>
          </div>

          <div class="row-divider"></div>
        </div>
      ))}
    </div>

    <div class="proj-footer sect-reveal">
      <a href="https://github.com/PriyanshuSingh44" target="_blank" rel="noopener" class="btn-ghost">
        All Repositories →
      </a>
    </div>
  </div>
</section>

<style>
.projects-section {
  padding: 110px 0;
  background: var(--black);
  position: relative;
  overflow: hidden;
}


.proj-heading {
  font-family: var(--font-head);
  font-size: clamp(2.5rem, 6vw, 5rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  color: var(--white);
  margin-bottom: 56px;
}
.accent-dot { color: var(--accent); }

/* ── Accordion ── */
.proj-accordion {
  display: flex;
  flex-direction: column;
  border-top: 1px solid var(--border);
  margin-bottom: 48px;
}

.proj-row {
  cursor: pointer;
  overflow: hidden;
  transition: background 0.3s ease;
  outline: none;
}

.proj-row:focus-visible { box-shadow: inset 0 0 0 1px rgba(0,210,255,0.4); }
.proj-row:hover { background: rgba(255,255,255,0.02); }
.proj-row.active { background: rgba(0,210,255,0.03); }

/* Collapsed bar */
.row-collapsed {
  display: grid;
  grid-template-columns: 52px 1fr auto 36px;
  align-items: center;
  gap: 20px;
  padding: 20px 0;
  transition: padding 0.35s ease;
}
.proj-row.active .row-collapsed { padding: 28px 0 16px; }

.row-num {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--gray-dim);
  letter-spacing: 0.1em;
}

.row-title {
  font-family: var(--font-head);
  font-size: clamp(1rem, 2.2vw, 1.35rem);
  font-weight: 600;
  color: var(--white);
  line-height: 1.2;
  transition: color 0.2s;
}
.proj-row:hover .row-title,
.proj-row.active .row-title { color: var(--accent); }

.row-metric {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--gray-dim);
  letter-spacing: 0.06em;
  white-space: nowrap;
  transition: color 0.2s;
}
.proj-row.active .row-metric { color: var(--red); }

.row-chevron {
  font-family: var(--font-mono);
  font-size: 1.1rem;
  color: var(--gray-dim);
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), color 0.2s;
  display: flex; align-items: center; justify-content: center;
  width: 32px; height: 32px;
  border: 1px solid var(--border);
  border-radius: 50%;
}
.proj-row.active .row-chevron {
  transform: rotate(45deg);
  color: var(--accent);
  border-color: rgba(0,210,255,0.3);
  background: rgba(0,210,255,0.06);
}

/* Expanded content — clip-path mask reveal */
.row-expanded {
  max-height: 0;
  overflow: hidden;
  clip-path: inset(0 0 100% 0);
  transition:
    max-height 0.55s cubic-bezier(0.4, 0, 0.2, 1),
    clip-path 0.55s cubic-bezier(0.4, 0, 0.2, 1);
}
.proj-row.active .row-expanded {
  max-height: 300px;
  clip-path: inset(0 0 0% 0);
}

.row-exp-inner {
  display: grid;
  grid-template-columns: 1fr 180px;
  gap: 40px;
  padding: 4px 0 28px 72px;
  align-items: end;
}

.row-kicker {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  color: var(--accent);
  letter-spacing: 0.06em;
  margin-bottom: 12px;
}

.row-desc {
  font-family: var(--font-mono);
  font-size: 0.82rem;
  color: var(--gray);
  line-height: 1.85;
  margin-bottom: 16px;
  max-width: 560px;
}

.row-tech {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.tech-pill {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  padding: 3px 10px;
  border-radius: 3px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.08);
  color: var(--gray);
}

.row-link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-mono);
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--accent);
  border: 1px solid rgba(0,210,255,0.35);
  padding: 10px 20px;
  border-radius: 3px;
  white-space: nowrap;
  transition: background 0.2s, transform 0.2s;
  text-decoration: none;
}
.row-link:hover {
  background: rgba(0,210,255,0.08);
  transform: translateY(-2px);
}
.arrow-icon { font-size: 1rem; transition: transform 0.2s; }
.row-link:hover .arrow-icon { transform: translateX(3px) translateY(-3px); }

.row-divider { height: 1px; background: var(--border); }

.proj-footer { text-align: center; }

@media (max-width: 768px) {
  .row-collapsed { grid-template-columns: 40px 1fr 28px; }
  .row-metric { display: none; }
  .row-exp-inner { grid-template-columns: 1fr; padding-left: 48px; }
}
@media (max-width: 480px) {
  .row-exp-inner { padding-left: 0; }
}
</style>

<script>
  const rows = document.querySelectorAll<HTMLElement>('#projAccordion .proj-row');

  rows.forEach(row => {
    const expand = row.querySelector<HTMLElement>('.row-expanded');

    const open = () => {
      rows.forEach(r => {
        r.classList.remove('active');
        r.setAttribute('aria-expanded', 'false');
        const e = r.querySelector<HTMLElement>('.row-expanded');
        if (e) e.setAttribute('aria-hidden', 'true');
      });
      row.classList.add('active');
      row.setAttribute('aria-expanded', 'true');
      if (expand) expand.setAttribute('aria-hidden', 'false');
    };

    row.addEventListener('click', open);
    row.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open(); }
    });

    // Hover micro-expand (scale just a tiny bit)
    row.addEventListener('mouseenter', () => {
      if (!row.classList.contains('active')) {
        (row.querySelector<HTMLElement>('.row-title') as HTMLElement).style.transform = 'translateX(4px)';
      }
    });
    row.addEventListener('mouseleave', () => {
      (row.querySelector<HTMLElement>('.row-title') as HTMLElement).style.transform = '';
    });
  });
</script>
